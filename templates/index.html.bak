<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exhibition Marketing Automation</title>
    <link rel="stylesheet" href="/static/css/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <header class="header">
            <div class="logo">
                <svg class="logo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M3 9h18M9 21V9"/>
                </svg>
                <h1>Exhibition Marketing Automation</h1>
            </div>
            <p class="subtitle">Generate, schedule, and publish marketing content for exhibition booth design companies</p>
        </header>

        <main class="main-content">
            <!-- Status Bar -->
            <section class="status-bar">
                <div class="ai-status" id="aiStatus">
                    <span class="status-dot"></span>
                    <span class="status-text">Checking AI status...</span>
                </div>
            </section>

            <!-- Tab Navigation -->
            <div class="main-tabs">
                <button class="main-tab active" data-section="generate">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                    </svg>
                    Generate Content
                </button>
                <button class="main-tab" data-section="schedule">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    Schedule Posts
                </button>
                <button class="main-tab" data-section="accounts">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    Social Accounts
                </button>
                <button class="main-tab" data-section="history">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                    </svg>
                    Campaigns
                </button>
            </div>

            <!-- Generate Content Section -->
            <section class="section active" id="section-generate">
                <div class="input-section">
                    <h2>Create Marketing Campaign</h2>
                    <form id="campaignForm" class="campaign-form">
                        <div class="form-group">
                            <label for="customer_industry">Customer Industry</label>
                            <select id="customer_industry" name="customer_industry" required>
                                <option value="">Select an industry...</option>
                                <option value="Technology">Technology & Software</option>
                                <option value="Healthcare">Healthcare & Medical</option>
                                <option value="Manufacturing">Manufacturing</option>
                                <option value="Retail">Retail & E-commerce</option>
                                <option value="Finance">Finance & Banking</option>
                                <option value="Automotive">Automotive</option>
                                <option value="Education">Education & EdTech</option>
                                <option value="Real Estate">Real Estate</option>
                                <option value="Food & Beverage">Food & Beverage</option>
                                <option value="Fashion & Apparel">Fashion & Apparel</option>
                                <option value="Energy & Utilities">Energy & Utilities</option>
                                <option value="Travel & Hospitality">Travel & Hospitality</option>
                                <option value="Entertainment & Media">Entertainment & Media</option>
                                <option value="Construction">Construction & Architecture</option>
                                <option value="Legal">Legal Services</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="exhibition_name">Exhibition Name</label>
                            <input type="text" id="exhibition_name" name="exhibition_name" 
                                   placeholder="e.g., CES 2026, Hannover Messe, Arab Health" required>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="ai_provider">Content Generation</label>
                                <select id="ai_provider" name="ai_provider">
                                    <option value="template">Template Based (Free)</option>
                                    <option value="openai">OpenAI (GPT-4)</option>
                                    <option value="deepseek">DeepSeek</option>
                                </select>
                            </div>
                        </div>
                        <button type="submit" class="btn-primary" id="generateBtn">
                            <span class="btn-text">Generate Marketing Content</span>
                            <span class="btn-loading" style="display: none;">
                                <svg class="spinner" viewBox="0 0 24 24">
                                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="30 70"/>
                                </svg>
                                Generating...
                            </span>
                        </button>
                    </form>
                </div>

                <!-- Results Section -->
                <div class="results-section" id="resultsSection" style="display: none;">
                    <div class="results-header">
                        <h2>Generated Marketing Content</h2>
                        <div class="results-actions">
                            <button class="btn-secondary" id="exportTxtBtn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
                                </svg>
                                Export TXT
                            </button>
                            <button class="btn-secondary" id="exportCsvBtn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
                                </svg>
                                Export CSV
                            </button>
                        </div>
                    </div>

                    <!-- Tabs -->
                    <div class="tabs">
                        <button class="tab-btn active" data-tab="linkedin">
                            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                            </svg>
                            LinkedIn
                        </button>
                        <button class="tab-btn" data-tab="facebook">
                            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                            </svg>
                            Facebook
                        </button>
                        <button class="tab-btn" data-tab="google">
                            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                                <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/>
                            </svg>
                            Google Business
                        </button>
                        <button class="tab-btn" data-tab="images">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                <circle cx="8.5" cy="8.5" r="1.5"/>
                                <polyline points="21 15 16 10 5 21"/>
                            </svg>
                            Image Prompts
                        </button>
                    </div>

                    <!-- Tab Content -->
                    <div class="tab-content active" id="tab-linkedin">
                        <div class="content-card">
                            <div class="card-header">
                                <h3>LinkedIn Post</h3>
                                <div class="card-actions">
                                    <button class="btn-copy" data-copy="linkedin">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                                        </svg>
                                        Copy
                                    </button>
                                    <button class="btn-schedule" data-platform="linkedin" data-content="linkedin">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                            <circle cx="12" cy="12" r="10"/>
                                            <polyline points="12 6 12 12 16 14"/>
                                        </svg>
                                        Schedule
                                    </button>
                                </div>
                            </div>
                            <pre class="content-text" id="linkedinContent"></pre>
                        </div>
                    </div>

                    <div class="tab-content" id="tab-facebook">
                        <div class="content-card">
                            <div class="card-header">
                                <h3>Facebook Post</h3>
                                <div class="card-actions">
                                    <button class="btn-copy" data-copy="facebook">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                                        </svg>
                                        Copy
                                    </button>
                                    <button class="btn-schedule" data-platform="facebook" data-content="facebook">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                            <circle cx="12" cy="12" r="10"/>
                                            <polyline points="12 6 12 12 16 14"/>
                                        </svg>
                                        Schedule
                                    </button>
                                </div>
                            </div>
                            <pre class="content-text" id="facebookContent"></pre>
                        </div>
                    </div>

                    <div class="tab-content" id="tab-google">
                        <div class="content-card">
                            <div class="card-header">
                                <h3>Google Business Profile Post</h3>
                                <div class="card-actions">
                                    <button class="btn-copy" data-copy="google">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                                        </svg>
                                        Copy
                                    </button>
                                    <button class="btn-schedule" data-platform="google_business" data-content="google">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                            <circle cx="12" cy="12" r="10"/>
                                            <polyline points="12 6 12 12 16 14"/>
                                        </svg>
                                        Schedule
                                    </button>
                                </div>
                            </div>
                            <pre class="content-text" id="googleContent"></pre>
                        </div>
                    </div>

                    <div class="tab-content" id="tab-images">
                        <div class="content-card">
                            <div class="card-header">
                                <h3>AI Image Generation Prompts</h3>
                                <button class="btn-copy" data-copy="images">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                        <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                                    </svg>
                                    Copy All
                                </button>
                            </div>
                            <div class="image-prompts" id="imagePrompts"></div>
                        </div>
                    </div>

                    <!-- Campaign Info -->
                    <div class="campaign-info">
                        <p><strong>Campaign ID:</strong> <span id="campaignId"></span></p>
                        <p><strong>Industry:</strong> <span id="industryDisplay"></span></p>
                        <p><strong>Exhibition:</strong> <span id="exhibitionDisplay"></span></p>
                    </div>
                </div>
            </section>

            <!-- Schedule Posts Section -->
            <section class="section" id="section-schedule">
                <div class="input-section">
                    <h2>Schedule a Post</h2>
                    <form id="scheduleForm" class="campaign-form">
                        <div class="form-group">
                            <label for="schedule_platform">Platform</label>
                            <select id="schedule_platform" name="platform" required>
                                <option value="linkedin">LinkedIn</option>
                                <option value="facebook">Facebook</option>
                                <option value="google_business">Google Business</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="schedule_account">Social Account</label>
                            <select id="schedule_account" name="account_id">
                                <option value="">Default Account</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="schedule_content">Content</label>
                            <textarea id="schedule_content" name="content" rows="5" 
                                      placeholder="Enter post content..." required></textarea>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="schedule_date">Date</label>
                                <input type="date" id="schedule_date" name="date" required>
                            </div>
                            <div class="form-group">
                                <label for="schedule_time">Time</label>
                                <input type="time" id="schedule_time" name="time" required>
                            </div>
                        </div>
                        <button type="submit" class="btn-primary">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                            Schedule Post
                        </button>
                    </form>
                </div>

                <!-- Scheduled Posts List -->
                <div class="scheduled-posts-section">
                    <h2>Scheduled Posts</h2>
                    <div class="scheduled-posts-filters">
                        <select id="filter_platform">
                            <option value="">All Platforms</option>
                            <option value="linkedin">LinkedIn</option>
                            <option value="facebook">Facebook</option>
                            <option value="google_business">Google Business</option>
                        </select>
                        <select id="filter_status">
                            <option value="">All Status</option>
                            <option value="scheduled">Scheduled</option>
                            <option value="published">Published</option>
                            <option value="failed">Failed</option>
                        </select>
                    </div>
                    <div id="scheduledPostsList" class="scheduled-posts-list">
                        <p class="no-data">No scheduled posts yet.</p>
                    </div>
                </div>
            </section>

            <!-- Social Accounts Section -->
            <section class="section" id="section-accounts">
                <div class="input-section">
                    <h2>Add Social Account</h2>
                    <form id="accountForm" class="campaign-form">
                        <div class="form-group">
                            <label for="account_platform">Platform</label>
                            <select id="account_platform" name="platform" required>
                                <option value="linkedin">LinkedIn</option>
                                <option value="facebook">Facebook</option>
                                <option value="google_business">Google Business</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="account_name">Account Name</label>
                            <input type="text" id="account_name" name="account_name" 
                                   placeholder="e.g., Company LinkedIn Page" required>
                        </div>
                        <div class="form-group">
                            <label for="account_id">Account ID (Optional)</label>
                            <input type="text" id="account_id" name="account_id" 
                                   placeholder="Platform-specific ID">
                        </div>
                        <div class="form-group">
                            <label for="access_token">Access Token</label>
                            <input type="password" id="access_token" name="access_token" 
                                   placeholder="API access token">
                        </div>
                        <button type="submit" class="btn-primary">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                <circle cx="8.5" cy="7" r="4"/>
                                <line x1="20" y1="8" x2="20" y2="14"/>
                                <line x1="23" y1="11" x2="17" y2="11"/>
                            </svg>
                            Add Account
                        </button>
                    </form>
                </div>

                <!-- Accounts List -->
                <div class="accounts-list-section">
                    <h2>Connected Accounts</h2>
                    <div id="accountsList" class="accounts-list">
                        <p class="no-data">No social accounts connected yet.</p>
                    </div>
                </div>
            </section>

            <!-- Campaigns History Section -->
            <section class="section" id="section-history">
                <div class="history-section">
                    <h2>Campaign History</h2>
                    <div id="campaignsList" class="campaigns-list">
                        <p class="no-data">No campaigns yet. Create your first one above!</p>
                    </div>
                </div>
            </section>
        </main>

        <!-- Schedule Modal -->
        <div class="modal" id="scheduleModal">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>Schedule Post</h3>
                    <button class="modal-close" id="closeScheduleModal">&times;</button>
                </div>
                <form id="modalScheduleForm">
                    <div class="form-group">
                        <label>Platform</label>
                        <input type="text" id="modal_platform" disabled>
                    </div>
                    <div class="form-group">
                        <label for="modal_account">Social Account</label>
                        <select id="modal_account">
                            <option value="">Default Account</option>
                        </select>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="modal_date">Date</label>
                            <input type="date" id="modal_date" required>
                        </div>
                        <div class="form-group">
                            <label for="modal_time">Time</label>
                            <input type="time" id="modal_time" required>
                        </div>
                    </div>
                    <input type="hidden" id="modal_content_type">
                    <div class="modal-actions">
                        <button type="button" class="btn-secondary" id="cancelScheduleModal">Cancel</button>
                        <button type="submit" class="btn-primary">Schedule</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Toast Notification -->
        <div class="toast" id="toast">
            <span class="toast-message"></span>
        </div>
    </div>

    <script src="/static/js/app.js"></script>
</body>
</html>
