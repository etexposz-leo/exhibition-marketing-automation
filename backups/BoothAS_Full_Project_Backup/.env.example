# Environment Configuration
# Set ENVIRONMENT=production for production deployments
# The app will refuse to start if SECRET_KEY or DATABASE_URL are missing in production
ENVIRONMENT=development

# Application Settings
# IMPORTANT: Generate a secure secret key for production
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secure-random-secret-key-min-32-chars

# Database Configuration
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/marketing
DATABASE_URL=sqlite:///./data/marketing.db

# Security
# Set to true for production with HTTPS
HTTPS_ONLY=false

# AI Services (optional - mock mode works without these)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Social Platform Credentials (optional - mock mode works without these)
LINKEDIN_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
X_BEARER_TOKEN=
GOOGLE_BUSINESS_API_KEY=

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
